{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "baseBranchPatterns": [
    "develop"
  ],
  "ignorePaths": [
    "/build/**"
  ],
  "configMigration": true,
  "minimumReleaseAge": "7 days",
  "timezone": "Europe/Berlin",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)Dockerfile$/"],
      "matchStrings": ["# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)(?: extractVersion=(?<extractVersion>.*?))?\\s(?:ENV|ARG) .*?_VERSION=(?<currentValue>.*)\\s"]
    }
  ]
}
